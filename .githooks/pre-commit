#!/bin/sh
# Block commits that contain secrets, before they ever leave the machine.
# This repo is public: a pushed secret is exposed instantly and cannot be un-leaked,
# so local detection is the only layer that actually prevents exposure.

if ! command -v trufflehog >/dev/null 2>&1; then
  echo "⚠  trufflehog not installed. Install: https://github.com/trufflesecurity/trufflehog#installation"
  echo "   (macOS: brew install trufflehog). Skipping local secret scan; CI will still scan."
  exit 0
fi

# --trust-local-git-config is required: without it TruffleHog can read 0 bytes
#   from a hook context and scan nothing (see trufflehog issue #4575).
# --results includes "unverified" so the hook also blocks findings it cannot
#   verify as live, e.g. a staged private key (which is exactly what we must
#   never let reach a public repo).
trufflehog git "file://$(git rev-parse --show-toplevel)" \
  --since-commit HEAD --results=verified,unknown,unverified \
  --fail --no-update --trust-local-git-config || {
    echo "✖  Secret detected. Commit blocked."
    echo "   Remove the secret AND rotate the key (assume it is already compromised)."
    exit 1
  }
